#!/bin/bash
# @parseArger-begin
# @parseArger-help "Query Z.ai coding plan limits and MCP usage" --option "help" --short-option "h"
# @parseArger-verbose --option "verbose" --level "0" --quiet-option "quiet"
_has_colors=0
if [ -t 1 ]; then # Check if stdout is a terminal
	ncolors=$(tput colors 2>/dev/null)
	if [ -n "$ncolors" ] && [ "$ncolors" -ge 8 ]; then
		_has_colors=1
	fi
fi
# @parseArger-declarations
# @parseArger opt conf "Key config file path" --short c
# @parseArger opt provider-config "Direct key override: zai::<api_key>[::<name>]"
# @parseArger opt name "Query specific key by name" --short n
# @parseArger opt usage-days "Token usage lookback in days" --short u
# @parseArger flag json "Output raw JSON" --short j
# @parseArger-declarations-end

# @parseArger-utils
_helpHasBeenPrinted=1;
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)";
# @parseArger-utils-end

# @parseArger-parsing

__cli_arg_count=$#;

die()
{
	local _ret=1
    if [[ -n "$2" ]] && [[ "$2" =~ ^[0-9]+$ ]]; then
   	_ret="$2"
    fi
	test "${_PRINT_HELP:-no}" = yes && print_help >&2
	log "$1" -3 >&2
	exit "${_ret}"
}


begins_with_short_option()
{
	local first_option all_short_options=''
	first_option="${1:0:1}"
	test "$all_short_options" = "${all_short_options/$first_option/}" && return 1 || return 0
}

# POSITIONALS ARGUMENTS
_positionals=();
_optional_positionals=();
# OPTIONALS ARGUMENTS
_arg_conf=
_arg_provider_config=
_arg_name=
_arg_usage_days=
# FLAGS
_arg_json="off"
# NESTED
_verbose_level="0";



print_help()
{
	_triggerSCHelp=1;

	if [[ "$_helpHasBeenPrinted" == "1" ]]; then
		_helpHasBeenPrinted=0;
		echo -e "Query Z.ai coding plan limits and MCP usage:"
	echo -e "	-c, --conf <conf>: Key config file path"
	echo -e "	--provider-config <provider-config>: Direct key override: zai::<api_key>[::<name>]"
	echo -e "	-n, --name <name>: Query specific key by name"
	echo -e "	-u, --usage-days <usage-days>: Token usage lookback in days"
	echo -e "	-j|--json|--no-json: Output raw JSON"
	echo -e "Usage :
	$0 [--conf <value>] [--provider-config <value>] [--name <value>] [--usage-days <value>] [--[no-]json]";
	fi

}

log() {
	local _arg_msg="${1}";
	local _arg_level="${2:-0}";
	if [ "${_arg_level}" -le "${_verbose_level}" ]; then
		case "$_arg_level" in
			-3)
				_arg_COLOR="[0;31m";
				;;
			-2)
				_arg_COLOR="[0;33m";
				;;
			-1)
				_arg_COLOR="[1;33m";
				;;
			1)
				_arg_COLOR="[0;32m";
				;;
			2)
				_arg_COLOR="[1;36m";
				;;
			3)
				_arg_COLOR="[0;36m";
				;;
			*)
				_arg_COLOR="[0m";
				;;
		esac
		if [ "${_has_colors}" == "1" ]; then
			echo -e "${_arg_COLOR}${_arg_msg}[0m";
		else
			echo "${_arg_msg}";
		fi
	fi
}

parse_commandline()
{
	_positionals_count=0
	while test $# -gt 0
	do
		_key="$1"
		case "$_key" in
			-c|--conf)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_conf="$2"
				shift
				;;
			--conf=*)
				_arg_conf="${_key##--conf=}"
				;;
			-c*)
				_arg_conf="${_key##-c}"
				;;
			
			--provider-config)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_provider_config="$2"
				shift
				;;
			--provider-config=*)
				_arg_provider_config="${_key##--provider-config=}"
				;;
			
			-n|--name)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_name="$2"
				shift
				;;
			--name=*)
				_arg_name="${_key##--name=}"
				;;
			-n*)
				_arg_name="${_key##-n}"
				;;
			
			-u|--usage-days)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_usage_days="$2"
				shift
				;;
			--usage-days=*)
				_arg_usage_days="${_key##--usage-days=}"
				;;
			-u*)
				_arg_usage_days="${_key##-u}"
				;;
			
			-j|--json)
				_arg_json="on"
				;;
			--no-json)
				_arg_json="off"
				;;
			-h|--help)
				print_help;
				exit 0;
				;;
			-h*)
				print_help;
				exit 0;
				;;
			--verbose)
				if [ $# -lt 2 ];then
					_verbose_level="$((_verbose_level + 1))";
				else
					_verbose_level="$2";
					shift;
				fi
				;;
			--quiet)
				if [ $# -lt 2 ];then
					_verbose_level="$((_verbose_level - 1))";
				else
					_verbose_level="-$2";
					shift;
				fi
				;;
			
				*)
				_last_positional="$1"
				_positionals+=("$_last_positional")
				_positionals_count=$((_positionals_count + 1))
				;;
		esac
		shift
	done
}


handle_passed_args_count()
{
	local _required_args_string=""
	if [ "${_positionals_count}" -gt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: There were spurious positional arguments --- we expect at most 0 (namely: $_required_args_string), but got ${_positionals_count} (the last one was: '${_last_positional}').
	${_positionals[*]}" 1
	fi
	if [ "${_positionals_count}" -lt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: Not enough positional arguments - we require at least 0 (namely: $_required_args_string), but got only ${_positionals_count}.
	${_positionals[*]}" 1;
	fi
}


assign_positional_args()
{
	local _positional_name _shift_for=$1;
	_positional_names="";
	shift "$_shift_for"
	for _positional_name in ${_positional_names};do
		test $# -gt 0 || break;
		eval "if [ \"\$_one_of${_positional_name}\" != \"\" ];then [[ \"\${_one_of${_positional_name}[*]}\" =~ \"\${1}\" ]];fi" || die "${_positional_name} must be one of: $(eval "echo \"\${_one_of${_positional_name}[*]}\"")" 1;
		local _match_var="_match${_positional_name}";
		local _regex="${!_match_var}";
		if [ -n "$_regex" ]; then
			[[ "${1}" =~ $_regex ]] || die "${_positional_name} does not match pattern: $_regex"
		fi
		eval "$_positional_name=\${1}" || die "Error during argument parsing, possibly an ParseArger bug." 1;
		shift;
	done
}

print_debug()
{
	print_help
	# shellcheck disable=SC2145
	echo "DEBUG: $0 $@";
	
	echo -e "	conf: ${_arg_conf}";
	echo -e "	provider-config: ${_arg_provider_config}";
	echo -e "	name: ${_arg_name}";
	echo -e "	usage-days: ${_arg_usage_days}";
	echo -e "	json: ${_arg_json}";

}


on_interrupt() {
	die Process aborted! 130;
}


parse_commandline "$@";
handle_passed_args_count;
assign_positional_args 1 "${_positionals[@]}";
trap on_interrupt INT;




# @parseArger-parsing-end

# Source library helpers
_lib_dir="$_SCRIPT_DIR/../lib"
if [ -d "$_lib_dir" ]; then
	for _lib_file in "$_lib_dir"/*.sh; do
		if [ -f "$_lib_file" ]; then
			# shellcheck source=/dev/null
			source "$_lib_file"
		fi
	done
fi

set -euo pipefail

# Provider identifier for this subcommand
_provider="zai"

if [ -z "$_arg_usage_days" ]; then
	_arg_usage_days=1
fi
if ! [[ "$_arg_usage_days" =~ ^[0-9]+$ ]] || [ "$_arg_usage_days" -lt 1 ]; then
	die "--usage-days must be a positive integer" 1
fi

format_number() {
	local value="$1"
	printf '%s' "$value" | sed ':a;s/\B[0-9]\{3\}\>/,&/;ta'
}

format_mtokens() {
	local value="$1"
	awk -v n="$value" 'BEGIN { printf "%.1fM tok", n / 1000000 }'
}

zai_usage_url() {
	local days="$1"
	local start end
	start="$(TZ=Asia/Shanghai date -d "$days days ago" '+%Y-%m-%d+%H:%M:%S')"
	end="$(TZ=Asia/Shanghai date '+%Y-%m-%d+%H:%M:%S')"
	printf 'https://api.z.ai/api/monitor/usage/model-usage?startTime=%s&endTime=%s' "$start" "$end"
}

# Load keys for this provider
declare -A _keys=()
config_load_keys "$_provider" "$_arg_conf" "$_arg_provider_config"

if [ "${#_keys[@]}" -eq 0 ]; then
	die "No keys found for provider: $_provider. Use --conf or --provider-config." 1
fi

# Filter to specific key if --name given
if [ -n "$_arg_name" ]; then
	if [ -z "${_keys[$_arg_name]+x}" ]; then
		die "Key not found: $_arg_name" 1
	fi
	_target_key="${_keys[$_arg_name]}"
	_keys=()
	_keys["$_arg_name"]="$_target_key"
fi

# Iterate over keys
_key_count=${#_keys[@]}
_current=0
_json_results=()
for _key_name in "${!_keys[@]}"; do
	_current=$((_current + 1))
	_key_value="${_keys[$_key_name]}"

	_url="https://api.z.ai/api/monitor/usage/quota/limit"
	http_get "$_url" "$_key_value" _response

	if [ "$_http_status" -ne 200 ]; then
		if [ "$_arg_json" = "on" ]; then
			_json_results+=("$(jq -n \
				--arg provider "$_provider" \
				--arg key_name "$_key_name" \
				--argjson status "$_http_status" \
				'{provider: $provider, key_name: $key_name, error: "HTTP \($status)"}')")
		else
			echo "Error: API returned status $_http_status for key $_key_name" >&2
		fi
		continue
	fi

	_level="$(echo "$_response" | jq -r '.data.level // "unknown"' 2>/dev/null)"

	# Extract TIME_LIMIT entry
	_time_limit="$(echo "$_response" | jq -c '.data.limits[] | select(.type == "TIME_LIMIT")' 2>/dev/null | head -1)"
	_tl_pct="0"
	_tl_resets="N/A"
	_tl_reset_s="0"
	_tl_mcp=""
	if [ -n "$_time_limit" ]; then
		_tl_pct="$(echo "$_time_limit" | jq -r '.percentage // 0' 2>/dev/null)"
		_tl_reset_ms="$(echo "$_time_limit" | jq -r '.nextResetTime // 0' 2>/dev/null)"
		_tl_reset_s=$((_tl_reset_ms / 1000))
		_tl_resets="$(time_format_remaining "$_tl_reset_s")"
		_tl_mcp="$(echo "$_time_limit" | jq -r '.usageDetails[]? | "\(.modelCode): \(.usage)"' 2>/dev/null | paste -sd ',' -)"
	fi

	# Extract TOKENS_LIMIT entry
	_tokens_limit="$(echo "$_response" | jq -c '.data.limits[] | select(.type == "TOKENS_LIMIT")' 2>/dev/null | head -1)"
	_tk_pct="0"
	_tk_resets="N/A"
	_tk_reset_s="0"
	if [ -n "$_tokens_limit" ]; then
		_tk_pct="$(echo "$_tokens_limit" | jq -r '.percentage // 0' 2>/dev/null)"
		_tk_reset_ms="$(echo "$_tokens_limit" | jq -r '.nextResetTime // 0' 2>/dev/null)"
		_tk_reset_s=$((_tk_reset_ms / 1000))
		_tk_resets="$(time_format_remaining "$_tk_reset_s")"
	fi

	_usage_response=""
	_usage_status="0"
	_usage_url="$(zai_usage_url "$_arg_usage_days")"
	http_get "$_usage_url" "$_key_value" _usage_response
	_usage_status="$_http_status"
	_usage_json="null"
	_usage_total_tokens="0"
	_usage_total_calls="0"
	_usage_models="[]"
	if [ "$_usage_status" -eq 200 ] && echo "$_usage_response" | jq -e '.data.totalUsage' >/dev/null 2>&1; then
		_usage_total_tokens="$(echo "$_usage_response" | jq -r '.data.totalUsage.totalTokensUsage // 0' 2>/dev/null)"
		_usage_total_calls="$(echo "$_usage_response" | jq -r '.data.totalUsage.totalModelCallCount // 0' 2>/dev/null)"
		_usage_models="$(echo "$_usage_response" | jq -c '[.data.modelDataList[]? | {model: .modelName, tokens: ([.tokensUsage[]?] | add // 0)} | select(.tokens > 0)]' 2>/dev/null)"
		_usage_json="$(jq -n \
			--argjson days "$_arg_usage_days" \
			--argjson total_tokens "$_usage_total_tokens" \
			--argjson total_model_calls "$_usage_total_calls" \
			--argjson models "$_usage_models" \
			--argjson raw "$_usage_response" \
			'{period_days: $days, total_tokens: $total_tokens, total_model_calls: $total_model_calls, models: $models, raw: $raw}')"
	fi

	# Unified JSON output
	if [ "$_arg_json" = "on" ]; then
		_limits_json="[]"
		_limits_json="$(echo "$_limits_json" | jq \
			--arg label "5h window" \
			--argjson pct "$_tk_pct" \
			--arg resets_in "$_tk_resets" \
			--argjson resets_at "$_tk_reset_s" \
			'. + [{label: $label, used_percent: $pct, resets_in: $resets_in, resets_at: $resets_at}]')"
		_limits_json="$(echo "$_limits_json" | jq \
			--arg label "Weekly" \
			--argjson pct "$_tl_pct" \
			--arg resets_in "$_tl_resets" \
			--argjson resets_at "$_tl_reset_s" \
			'. + [{label: $label, used_percent: $pct, resets_in: $resets_in, resets_at: $resets_at}]')"

		_mcp_json="null"
		if [ -n "$_tl_mcp" ]; then
			_mcp_json="$(jq -R -s 'split(",") | map(split(": ") | {(.[0]): .[1]}) | add // null' <<< "$_tl_mcp")"
		fi

		_json_results+=("$(jq -n \
			--arg provider "$_provider" \
			--arg key_name "$_key_name" \
			--arg plan "$_level" \
			--argjson limits "$_limits_json" \
			--argjson usage "$_usage_json" \
			--argjson mcp "$_mcp_json" \
			--argjson raw "$_response" \
			'{provider: $provider, key_name: $key_name, plan: $plan, limits: $limits, credits: null, usage: $usage, extra: {mcp_usage: $mcp}, raw: $raw}')")
		continue
	fi

	output_section "Z.ai Coding Plan" "$_level"
	output_limit_bar "5h window" "$_tk_pct" "$_tk_resets"
	output_limit_bar "Weekly" "$_tl_pct" "$_tl_resets"
	if [ -n "$_tl_mcp" ]; then
		printf '│  └─ MCP usage: %s\n' "$_tl_mcp"
	fi
	if [ "$_usage_json" != "null" ]; then
		printf '│  %-14s %s, %s calls over %sd\n' \
			"Token usage:" "$(format_mtokens "$_usage_total_tokens")" "$(format_number "$_usage_total_calls")" "$_arg_usage_days"
		_usage_model_lines="$(echo "$_usage_models" | jq -r '.[] | "\(.model | sub("^GLM-"; "")): \(.tokens / 1000000 | (. * 10 | round / 10))M"' 2>/dev/null | paste -sd ',' -)"
		if [ -n "$_usage_model_lines" ]; then
			printf '│  └─ Models: %s\n' "$_usage_model_lines"
		fi
	elif [ "$_usage_status" -ne 200 ]; then
		printf '│  Token usage: unavailable (HTTP %s)\n' "$_usage_status" >&2
	fi
done

if [ "$_arg_json" = "on" ]; then
	_json_array="["
	_first=1
	for _result in "${_json_results[@]}"; do
		if [ "$_first" -eq 1 ]; then
			_json_array="${_json_array}${_result}"
			_first=0
		else
			_json_array="${_json_array},${_result}"
		fi
	done
	_json_array="${_json_array}]"
	json_output "$_json_array"
fi

# print_debug "$@"
# @parseArger-end
