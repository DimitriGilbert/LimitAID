#!/bin/bash
# @parseArger-begin
# @parseArger-help "Query Codex/OpenAI + Spark rate limits" --option "help" --short-option "h"
# @parseArger-verbose --option "verbose" --level "0" --quiet-option "quiet"
_has_colors=0
if [ -t 1 ]; then # Check if stdout is a terminal
	ncolors=$(tput colors 2>/dev/null)
	if [ -n "$ncolors" ] && [ "$ncolors" -ge 8 ]; then
		_has_colors=1
	fi
fi
# @parseArger-declarations
# @parseArger opt conf "Key config file path" --short c
# @parseArger opt provider-config "Direct key override: codex::<access_token>[::<name>]"
# @parseArger flag json "Output raw JSON" --short j
# @parseArger-declarations-end

# @parseArger-utils
_helpHasBeenPrinted=1;
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)";
# @parseArger-utils-end

# @parseArger-parsing

__cli_arg_count=$#;

die()
{
	local _ret=1
    if [[ -n "$2" ]] && [[ "$2" =~ ^[0-9]+$ ]]; then
   	_ret="$2"
    fi
	test "${_PRINT_HELP:-no}" = yes && print_help >&2
	log "$1" -3 >&2
	exit "${_ret}"
}


begins_with_short_option()
{
	local first_option all_short_options=''
	first_option="${1:0:1}"
	test "$all_short_options" = "${all_short_options/$first_option/}" && return 1 || return 0
}

# POSITIONALS ARGUMENTS
_positionals=();
_optional_positionals=();
# OPTIONALS ARGUMENTS
_arg_conf=
_arg_provider_config=
# FLAGS
_arg_json="off"
# NESTED
_verbose_level="0";



print_help()
{
	_triggerSCHelp=1;

	if [[ "$_helpHasBeenPrinted" == "1" ]]; then
		_helpHasBeenPrinted=0;
		echo -e "Query Codex/OpenAI + Spark rate limits:"
	echo -e "	-c, --conf <conf>: Key config file path"
	echo -e "	--provider-config <provider-config>: Direct key override: codex::<access_token>[::<name>]"
	echo -e "	-j|--json|--no-json: Output raw JSON"
	echo -e "Usage :
	$0 [--conf <value>] [--provider-config <value>] [--[no-]json]";
	fi

}

log() {
	local _arg_msg="${1}";
	local _arg_level="${2:-0}";
	if [ "${_arg_level}" -le "${_verbose_level}" ]; then
		case "$_arg_level" in
			-3)
				_arg_COLOR="[0;31m";
				;;
			-2)
				_arg_COLOR="[0;33m";
				;;
			-1)
				_arg_COLOR="[1;33m";
				;;
			1)
				_arg_COLOR="[0;32m";
				;;
			2)
				_arg_COLOR="[1;36m";
				;;
			3)
				_arg_COLOR="[0;36m";
				;;
			*)
				_arg_COLOR="[0m";
				;;
		esac
		if [ "${_has_colors}" == "1" ]; then
			echo -e "${_arg_COLOR}${_arg_msg}[0m";
		else
			echo "${_arg_msg}";
		fi
	fi
}

parse_commandline()
{
	_positionals_count=0
	while test $# -gt 0
	do
		_key="$1"
		case "$_key" in
			-c|--conf)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_conf="$2"
				shift
				;;
			--conf=*)
				_arg_conf="${_key##--conf=}"
				;;
			-c*)
				_arg_conf="${_key##-c}"
				;;
			
			--provider-config)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_provider_config="$2"
				shift
				;;
			--provider-config=*)
				_arg_provider_config="${_key##--provider-config=}"
				;;
			
			-j|--json)
				_arg_json="on"
				;;
			--no-json)
				_arg_json="off"
				;;
			-h|--help)
				print_help;
				exit 0;
				;;
			-h*)
				print_help;
				exit 0;
				;;
			--verbose)
				if [ $# -lt 2 ];then
					_verbose_level="$((_verbose_level + 1))";
				else
					_verbose_level="$2";
					shift;
				fi
				;;
			--quiet)
				if [ $# -lt 2 ];then
					_verbose_level="$((_verbose_level - 1))";
				else
					_verbose_level="-$2";
					shift;
				fi
				;;
			
				*)
				_last_positional="$1"
				_positionals+=("$_last_positional")
				_positionals_count=$((_positionals_count + 1))
				;;
		esac
		shift
	done
}


handle_passed_args_count()
{
	local _required_args_string=""
	if [ "${_positionals_count}" -gt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: There were spurious positional arguments --- we expect at most 0 (namely: $_required_args_string), but got ${_positionals_count} (the last one was: '${_last_positional}').
	${_positionals[*]}" 1
	fi
	if [ "${_positionals_count}" -lt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: Not enough positional arguments - we require at least 0 (namely: $_required_args_string), but got only ${_positionals_count}.
	${_positionals[*]}" 1;
	fi
}


assign_positional_args()
{
	local _positional_name _shift_for=$1;
	_positional_names="";
	shift "$_shift_for"
	for _positional_name in ${_positional_names};do
		test $# -gt 0 || break;
		eval "if [ \"\$_one_of${_positional_name}\" != \"\" ];then [[ \"\${_one_of${_positional_name}[*]}\" =~ \"\${1}\" ]];fi" || die "${_positional_name} must be one of: $(eval "echo \"\${_one_of${_positional_name}[*]}\"")" 1;
		local _match_var="_match${_positional_name}";
		local _regex="${!_match_var}";
		if [ -n "$_regex" ]; then
			[[ "${1}" =~ $_regex ]] || die "${_positional_name} does not match pattern: $_regex"
		fi
		eval "$_positional_name=\${1}" || die "Error during argument parsing, possibly an ParseArger bug." 1;
		shift;
	done
}

print_debug()
{
	print_help
	# shellcheck disable=SC2145
	echo "DEBUG: $0 $@";
	
	echo -e "	conf: ${_arg_conf}";
	echo -e "	provider-config: ${_arg_provider_config}";
	echo -e "	json: ${_arg_json}";

}


on_interrupt() {
	die Process aborted! 130;
}


parse_commandline "$@";
handle_passed_args_count;
assign_positional_args 1 "${_positionals[@]}";
trap on_interrupt INT;




# @parseArger-parsing-end

# Source library helpers
_lib_dir="$_SCRIPT_DIR/../lib"
if [ -d "$_lib_dir" ]; then
	for _lib_file in "$_lib_dir"/*.sh; do
		if [ -f "$_lib_file" ]; then
			# shellcheck source=/dev/null
			source "$_lib_file"
		fi
	done
fi

set -euo pipefail

# Provider identifier for this subcommand
_provider="codex"

# Load keys for this provider
declare -A _keys=()
config_load_keys "$_provider" "$_arg_conf" "$_arg_provider_config"

if [ "${#_keys[@]}" -eq 0 ]; then
	die "No keys found for provider: $_provider. Use --conf or --provider-config." 1
fi

# Helper: build a progress bar string (█/░) for a given percentage and width
_build_bar() {
	local _pct="$1" _width="${2:-20}"
	local _filled=$(( _pct * _width / 100 ))
	local _empty=$(( _width - _filled ))
	local _bar="" _i
	for (( _i=0; _i<_filled; _i++ )); do _bar="${_bar}█"; done
	for (( _i=0; _i<_empty; _i++ )); do _bar="${_bar}░"; done
	printf '%s' "$_bar"
}

_key_count=${#_keys[@]}
_current=0
for _key_name in "${!_keys[@]}"; do
	_current=$((_current + 1))
	_key_value="${_keys[$_key_name]}"

	_url="https://chatgpt.com/backend-api/wham/usage"
	http_get "$_url" "$_key_value" _response

	if [ "$_http_status" -ne 200 ]; then
		echo "Error: API returned status $_http_status" >&2
		continue
	fi

	# Raw JSON passthrough
	if [ "$_arg_json" = "on" ]; then
		echo "$_response"
		continue
	fi

	# Extract top-level fields
	_plan_type="$(echo "$_response" | jq -r '.plan_type // "unknown"')"
	_pri_pct="$(echo "$_response" | jq -r '.rate_limit.primary_window.used_percent // 0')"
	_pri_win="$(echo "$_response" | jq -r '.rate_limit.primary_window.limit_window_seconds // 0')"
	_pri_reset="$(echo "$_response" | jq -r '.rate_limit.primary_window.reset_at // 0')"
	_sec_pct="$(echo "$_response" | jq -r '.rate_limit.secondary_window.used_percent // 0')"
	_sec_win="$(echo "$_response" | jq -r '.rate_limit.secondary_window.limit_window_seconds // 0')"
	_sec_reset="$(echo "$_response" | jq -r '.rate_limit.secondary_window.reset_at // 0')"
	_credit_bal="$(echo "$_response" | jq -r '.credits.balance // "0"')"
	_credit_ul="$(echo "$_response" | jq -r '.credits.unlimited // false')"

	_pri_label="$(time_format_window "$_pri_win")"
	_pri_resets="$(time_format_remaining "$_pri_reset")"
	_sec_label="$(time_format_window "$_sec_win")"
	_sec_resets="$(time_format_remaining "$_sec_reset")"

	output_section "Codex/OpenAI" "$_plan_type"
	output_limit_bar "$_pri_label" "$_pri_pct" "$_pri_resets"
	output_limit_bar "$_sec_label" "$_sec_pct" "$_sec_resets"

	# Credits line
	if [ "$_credit_ul" = "true" ]; then
		printf '│  %-14s unlimited\n' "Credits:"
	else
		printf '│  %-14s $%s\n' "Credits:" "$_credit_bal"
	fi

	# Spark sub-limits (nested under additional_rate_limits)
	# Use jq array indexing to get first match (avoids head -1 truncating JSON)
	_spark="$(echo "$_response" | jq '
		[.additional_rate_limits[]?
		| select(.limit_name // "" | test("spark"; "i"))
		| .rate_limit // empty][0] // empty
	')"

	if [ -n "$_spark" ]; then
		_sp_pri_pct="$(echo "$_spark" | jq -r '.primary_window.used_percent // 0')"
		_sp_pri_win="$(echo "$_spark" | jq -r '.primary_window.limit_window_seconds // 0')"
		_sp_pri_reset="$(echo "$_spark" | jq -r '.primary_window.reset_at // 0')"
		_sp_sec_pct="$(echo "$_spark" | jq -r '.secondary_window.used_percent // 0')"
		_sp_sec_win="$(echo "$_spark" | jq -r '.secondary_window.limit_window_seconds // 0')"
		_sp_sec_reset="$(echo "$_spark" | jq -r '.secondary_window.reset_at // 0')"

		_sp_pri_label="$(time_format_window "$_sp_pri_win")"
		_sp_pri_resets="$(time_format_remaining "$_sp_pri_reset")"
		_sp_sec_label="$(time_format_window "$_sp_sec_win")"
		_sp_sec_resets="$(time_format_remaining "$_sp_sec_reset")"

		_sp_pri_bar="$(_build_bar "$_sp_pri_pct")"
		_sp_sec_bar="$(_build_bar "$_sp_sec_pct")"

		printf '└─ Spark:\n'
		printf '   ├─ %-14s %3d%% used %s resets in %s\n' \
			"${_sp_pri_label}:" "$_sp_pri_pct" "$_sp_pri_bar" "$_sp_pri_resets"
		printf '   └─ %-14s %3d%% used %s resets in %s\n' \
			"${_sp_sec_label}:" "$_sp_sec_pct" "$_sp_sec_bar" "$_sp_sec_resets"
	fi

	if [ "$_current" -lt "$_key_count" ]; then
		output_tree_branch
	fi
done

# print_debug "$@"
# @parseArger-end
