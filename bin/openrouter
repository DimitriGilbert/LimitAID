#!/bin/bash
# @parseArger-begin
# @parseArger-help "Query OpenRouter key balance and usage" --option "help" --short-option "h"
# @parseArger-verbose --option "verbose" --level "0" --quiet-option "quiet"
_has_colors=0
if [ -t 1 ]; then # Check if stdout is a terminal
	ncolors=$(tput colors 2>/dev/null)
	if [ -n "$ncolors" ] && [ "$ncolors" -ge 8 ]; then
		_has_colors=1
	fi
fi
# @parseArger-declarations
# @parseArger opt conf "Key config file path" --short c
# @parseArger opt provider-config "Direct key override: openrouter::<api_key>[::<name>]"
# @parseArger opt name "Query specific key by name" --short n
# @parseArger flag json "Output raw JSON" --short j
# @parseArger-declarations-end

# @parseArger-utils
_helpHasBeenPrinted=1;
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)";
# @parseArger-utils-end

# @parseArger-parsing

__cli_arg_count=$#;

die()
{
	local _ret=1
    if [[ -n "$2" ]] && [[ "$2" =~ ^[0-9]+$ ]]; then
   	_ret="$2"
    fi
	test "${_PRINT_HELP:-no}" = yes && print_help >&2
	log "$1" -3 >&2
	exit "${_ret}"
}


begins_with_short_option()
{
	local first_option all_short_options=''
	first_option="${1:0:1}"
	test "$all_short_options" = "${all_short_options/$first_option/}" && return 1 || return 0
}

# POSITIONALS ARGUMENTS
_positionals=();
_optional_positionals=();
# OPTIONALS ARGUMENTS
_arg_conf=
_arg_provider_config=
_arg_name=
# FLAGS
_arg_json="off"
# NESTED
_verbose_level="0";



print_help()
{
	_triggerSCHelp=1;

	if [[ "$_helpHasBeenPrinted" == "1" ]]; then
		_helpHasBeenPrinted=0;
		echo -e "Query OpenRouter key balance and usage:"
	echo -e "	-c, --conf <conf>: Key config file path"
	echo -e "	--provider-config <provider-config>: Direct key override: openrouter::<api_key>[::<name>]"
	echo -e "	-n, --name <name>: Query specific key by name"
	echo -e "	-j|--json|--no-json: Output raw JSON"
	echo -e "Usage :
	$0 [--conf <value>] [--provider-config <value>] [--name <value>] [--[no-]json]";
	fi

}

log() {
	local _arg_msg="${1}";
	local _arg_level="${2:-0}";
	if [ "${_arg_level}" -le "${_verbose_level}" ]; then
		case "$_arg_level" in
			-3)
				_arg_COLOR="[0;31m";
				;;
			-2)
				_arg_COLOR="[0;33m";
				;;
			-1)
				_arg_COLOR="[1;33m";
				;;
			1)
				_arg_COLOR="[0;32m";
				;;
			2)
				_arg_COLOR="[1;36m";
				;;
			3)
				_arg_COLOR="[0;36m";
				;;
			*)
				_arg_COLOR="[0m";
				;;
		esac
		if [ "${_has_colors}" == "1" ]; then
			echo -e "${_arg_COLOR}${_arg_msg}[0m";
		else
			echo "${_arg_msg}";
		fi
	fi
}

parse_commandline()
{
	_positionals_count=0
	while test $# -gt 0
	do
		_key="$1"
		case "$_key" in
			-c|--conf)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_conf="$2"
				shift
				;;
			--conf=*)
				_arg_conf="${_key##--conf=}"
				;;
			-c*)
				_arg_conf="${_key##-c}"
				;;
			
			--provider-config)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_provider_config="$2"
				shift
				;;
			--provider-config=*)
				_arg_provider_config="${_key##--provider-config=}"
				;;
			
			-n|--name)
				test $# -lt 2 && die "Missing value for the option: '$_key'" 1
				_arg_name="$2"
				shift
				;;
			--name=*)
				_arg_name="${_key##--name=}"
				;;
			-n*)
				_arg_name="${_key##-n}"
				;;
			
			-j|--json)
				_arg_json="on"
				;;
			--no-json)
				_arg_json="off"
				;;
			-h|--help)
				print_help;
				exit 0;
				;;
			-h*)
				print_help;
				exit 0;
				;;
			--verbose)
				if [ $# -lt 2 ];then
					_verbose_level="$((_verbose_level + 1))";
				else
					_verbose_level="$2";
					shift;
				fi
				;;
			--quiet)
				if [ $# -lt 2 ];then
					_verbose_level="$((_verbose_level - 1))";
				else
					_verbose_level="-$2";
					shift;
				fi
				;;
			
				*)
				_last_positional="$1"
				_positionals+=("$_last_positional")
				_positionals_count=$((_positionals_count + 1))
				;;
		esac
		shift
	done
}


handle_passed_args_count()
{
	local _required_args_string=""
	if [ "${_positionals_count}" -gt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: There were spurious positional arguments --- we expect at most 0 (namely: $_required_args_string), but got ${_positionals_count} (the last one was: '${_last_positional}').
	${_positionals[*]}" 1
	fi
	if [ "${_positionals_count}" -lt 0 ] && [ "$_helpHasBeenPrinted" == "1" ];then
		_PRINT_HELP=yes die "FATAL ERROR: Not enough positional arguments - we require at least 0 (namely: $_required_args_string), but got only ${_positionals_count}.
	${_positionals[*]}" 1;
	fi
}


assign_positional_args()
{
	local _positional_name _shift_for=$1;
	_positional_names="";
	shift "$_shift_for"
	for _positional_name in ${_positional_names};do
		test $# -gt 0 || break;
		eval "if [ \"\$_one_of${_positional_name}\" != \"\" ];then [[ \"\${_one_of${_positional_name}[*]}\" =~ \"\${1}\" ]];fi" || die "${_positional_name} must be one of: $(eval "echo \"\${_one_of${_positional_name}[*]}\"")" 1;
		local _match_var="_match${_positional_name}";
		local _regex="${!_match_var}";
		if [ -n "$_regex" ]; then
			[[ "${1}" =~ $_regex ]] || die "${_positional_name} does not match pattern: $_regex"
		fi
		eval "$_positional_name=\${1}" || die "Error during argument parsing, possibly an ParseArger bug." 1;
		shift;
	done
}

print_debug()
{
	print_help
	# shellcheck disable=SC2145
	echo "DEBUG: $0 $@";
	
	echo -e "	conf: ${_arg_conf}";
	echo -e "	provider-config: ${_arg_provider_config}";
	echo -e "	name: ${_arg_name}";
	echo -e "	json: ${_arg_json}";

}


on_interrupt() {
	die Process aborted! 130;
}


parse_commandline "$@";
handle_passed_args_count;
assign_positional_args 1 "${_positionals[@]}";
trap on_interrupt INT;




# @parseArger-parsing-end

# Source library helpers
_lib_dir="$_SCRIPT_DIR/../lib"
if [ -d "$_lib_dir" ]; then
	for _lib_file in "$_lib_dir"/*.sh; do
		if [ -f "$_lib_file" ]; then
			# shellcheck source=/dev/null
			source "$_lib_file"
		fi
	done
fi

set -euo pipefail

# Provider identifier for this subcommand
_provider="openrouter"

# Load keys for this provider
declare -A _keys=()
config_load_keys "$_provider" "$_arg_conf" "$_arg_provider_config"

if [ "${#_keys[@]}" -eq 0 ]; then
	log "No keys found for provider: $_provider. Use --conf or --provider-config." 2
	exit 0
fi

# Filter to specific key if --name given
if [ -n "$_arg_name" ]; then
	if [ -z "${_keys[$_arg_name]+x}" ]; then
		die "Key not found: $_arg_name" 1
	fi
	_target_key="${_keys[$_arg_name]}"
	_keys=()
	_keys["$_arg_name"]="$_target_key"
fi

# Iterate over keys
_key_count=${#_keys[@]}
_current=0
for _key_name in "${!_keys[@]}"; do
	_current=$((_current + 1))
	_key_value="${_keys[$_key_name]}"
	_key_preview="$(echo "$_key_value" | head -c 5)...$(echo "$_key_value" | tail -c 4)"

	_url="https://openrouter.ai/api/v1/key"
	http_get "$_url" "$_key_value" _response

	if [ "$_http_status" -ne 200 ]; then
		echo "Error: API returned status $_http_status for key $_key_name" >&2
		continue
	fi

	if [ "$_arg_json" = "on" ]; then
		echo "$_response"
		continue
	fi

	_label="$(echo "$_response" | jq -r '.data.label // "unlabeled"' 2>/dev/null)"
	_limit="$(echo "$_response" | jq -r '.data.limit // "null"' 2>/dev/null)"
	_limit_rem="$(echo "$_response" | jq -r '.data.limit_remaining // "null"' 2>/dev/null)"
	_usage_daily="$(echo "$_response" | jq -r '.data.usage_daily // 0' 2>/dev/null)"
	_usage_weekly="$(echo "$_response" | jq -r '.data.usage_weekly // 0' 2>/dev/null)"
	_usage_monthly="$(echo "$_response" | jq -r '.data.usage_monthly // 0' 2>/dev/null)"
	_is_free="$(echo "$_response" | jq -r '.data.is_free_tier // false' 2>/dev/null)"

	# Build key display name
	_display="$_key_name ($_key_preview)"
	if [ "$_is_free" = "true" ]; then
		_display="$_display, free tier"
	fi

	output_section "OpenRouter" "$_label"

	if [ "$_limit" = "null" ]; then
		printf '├─ %-14s unlimited\n' "Limit:"
		printf '├─ %-14s $%s\n' "Usage today:" "$_usage_daily"
		printf '└─ %-14s $%s\n' "Usage monthly:" "$_usage_monthly"
	else
		if [ "$_limit_rem" = "null" ]; then
			printf '├─ %-14s $%s\n' "Limit:" "$_limit"
			printf '├─ %-14s unlimited\n' "Remaining:"
		else
			_pct="$(echo "scale=0; $_limit_rem * 100 / $_limit" | bc 2>/dev/null || echo "0")"
			printf '├─ %-14s $%s\n' "Limit:" "$_limit"
			printf '├─ %-14s $%s / $%s (%s%%)\n' "Remaining:" "$_limit_rem" "$_limit" "$_pct"
		fi
		printf '├─ %-14s $%s\n' "Usage today:" "$_usage_daily"
		printf '├─ %-14s $%s\n' "Usage this week:" "$_usage_weekly"
		printf '└─ %-14s $%s\n' "Usage this month:" "$_usage_monthly"
	fi

	# Blank line between keys if more keys follow
	if [ "$_current" -lt "$_key_count" ]; then
		echo ""
	fi
done

# print_debug "$@"
# @parseArger-end
